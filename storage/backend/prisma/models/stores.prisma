model StoreTable {
  id   Int       @id @default(autoincrement())
  name String    @db.VarChar(255)
  type StoreType
  href String?

  sold_items      ItemTable[]          @relation(name: "retailer_items")
  published_items ItemTable[]          @relation(name: "brand_items")
  locations       StoreLocationTable[]

  @@map("stores")
}

enum StoreType {
  AUTH
  RETAIL
}

model StoreLocationTable {
  store_id    Int
  store       StoreTable    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  city_id     String        @db.VarChar(32)
  city        CityTable     @relation(fields: [city_id], references: [id], onDelete: Cascade)
  district_id String        @db.VarChar(32)
  district    DistrictTable @relation(fields: [district_id], references: [id], onDelete: Cascade)

  @@id([store_id, city_id, district_id])
  @@map("stores_locations")
}
